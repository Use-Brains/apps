{
  "expo": {
    "name": "AI Notecards",
    "slug": "ai-notecards",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ai-notecards",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ainotecards.app",
      "associatedDomains": [
        "applinks:ainotecards.com"
      ],
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F2",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.ainotecards.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-image-picker",
      "expo-notifications",
      "@react-native-google-signin/google-signin",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": ""
      }
    },
    "owner": "blue-expos-organization"
  }
}
