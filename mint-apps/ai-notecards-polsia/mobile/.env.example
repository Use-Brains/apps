# App environment
APP_ENV=development

# API base URL (Express backend)
EXPO_PUBLIC_API_URL=http://localhost:3001/api

# EAS project metadata
EXPO_PUBLIC_EAS_PROJECT_ID=

# Optional iOS bundle ID overrides
IOS_BUNDLE_ID_DEV=com.ainotecards.dev
IOS_BUNDLE_ID_PREVIEW=com.ainotecards.preview
IOS_BUNDLE_ID_PRODUCTION=com.ainotecards.app

# Google OAuth iOS client ID
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# RevenueCat API keys (subscriptions)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT=pro
