{
  "name": "ai-notecards-mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "APP_ENV=development expo start --dev-client --localhost",
    "codegen:ios": "node ./node_modules/react-native/scripts/generate-codegen-artifacts.js --path . --outputPath ios --targetPlatform ios",
    "android": "expo run:android",
    "ios": "npm run codegen:ios && expo run:ios",
    "ios:simulator": "npm run codegen:ios && APP_ENV=development expo run:ios",
    "build:ios:development": "APP_ENV=development npx eas-cli build --platform ios --profile development-device",
    "build:ios:simulator": "APP_ENV=development npx eas-cli build --platform ios --profile development-simulator",
    "build:ios:preview": "APP_ENV=preview npx eas-cli build --platform ios --profile preview",
    "build:ios:production": "APP_ENV=production npx eas-cli build --platform ios --profile production",
    "web": "expo start --web",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "^8.4.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "expo": "~55.0.5",
    "expo-apple-authentication": "~55.0.8",
    "expo-blur": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-dev-client": "~55.0.13",
    "expo-device": "~55.0.9",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.11",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "^55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-purchases": "^9.12.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "private": true
}
